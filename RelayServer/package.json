{
  "name": "rtc-database-relay",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "pnpm --filter @rtc-database/shared-relay build && tsx watch src/index.ts",
    "build": "pnpm --filter @rtc-database/shared-relay build && tsc -p tsconfig.json",
    "build:exe": "pnpm run build && pkg dist/index.js --targets node18-win-x64 --output release-builds/rtc-database-relay.exe",
    "start": "node dist/index.js",
    "start:exe": "release-builds/rtc-database-relay.exe"
  },
  "dependencies": {
    "@rtc-database/shared-relay": "workspace:*",
    "dotenv": "^17.2.3",
    "http-proxy": "^1.18.1",
    "pkg": "^5.8.1",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^20.19.22",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
