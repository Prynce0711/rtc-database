# Upstream server reachable from relay (for example Tailscale address)
RELAY_TARGET_URL=http://100.64.0.10:3000

# Local reverse proxy listener used by LAN clients
RELAY_LISTEN_HOST=0.0.0.0
RELAY_PORT=3000

# Optional: true to allow self-signed HTTPS upstream certificates
RELAY_INSECURE_TLS=false

# UDP discovery listener port
UDP_PORT=41234

# Host/port to advertise to LAN clients (defaults to RELAY_PORT)
UDP_ADVERTISED_HOST=localhost
UDP_ADVERTISED_PORT=3000
