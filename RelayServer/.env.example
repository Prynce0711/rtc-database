# Upstream server reachable from relay (for example Tailscale address)
RELAY_TARGET_URL=http://localhost:3000

# Local reverse proxy listener used by LAN clients
RELAY_LISTEN_HOST=0.0.0.0
RELAY_PORT=3443

# Optional: true to allow self-signed HTTPS upstream certificates
RELAY_INSECURE_TLS=false

# Optional: enable to rewrite the incoming Origin header and matching x-forwarded-* values.
# If RELAY_OVERRIDE_ORIGIN_URL is empty, RELAY_TARGET_URL is used.
RELAY_OVERRIDE_ORIGIN=false
# RELAY_OVERRIDE_ORIGIN_URL=https://your-domain.com

# Enable HTTPS listener for LAN clients
RELAY_USE_HTTPS=true

# Optional TLS file locations for relay listener. Relative paths are resolved from RelayServer/.
# RELAY_TLS_DIR=.relay-tls
# RELAY_TLS_KEY_PATH=.relay-tls/relay.key
# RELAY_TLS_CERT_PATH=.relay-tls/relay.crt
# RELAY_TLS_AUTO_GENERATE=true
# RELAY_TLS_CERT_HOSTS=localhost,127.0.0.1

# UDP discovery listener port
UDP_PORT=41234
# Optional: multicast group used for discovery requests.
# UDP_MULTICAST_GROUP=239.255.67.89

# Host/port to advertise to LAN clients (defaults to RELAY_PORT)
# The relay auto-discovers active LAN IPv4 addresses.
# Optionally add one extra hostname/IP for clients to try.
# UDP_ADVERTISED_HOST=relay.local
UDP_ADVERTISED_PORT=3443
# Optional: override protocol advertised to clients (http or https).
UDP_ADVERTISED_PROTOCOL=https
