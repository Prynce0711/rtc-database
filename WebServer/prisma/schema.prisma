// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ChatType {
  GROUP
  DIRECT
}

enum Roles {
  admin
  user
  atty
  statistics
  notarial
  archive
}

enum EmploymentType {
  PERMANENT
  CONTRACTUAL
  CASUAL
}

enum CaseType {
  CRIMINAL
  CIVIL
  LAND_REGISTRATION_CASE
  PETITION
  ELECTION
  SCA
  SHERRIFF
  UNKNOWN
}

enum Status {
  INACTIVE
  ACTIVE
  DEACTIVATED
  PENDING
  SUSPENDED
  TERMINATED
}

enum BloodType {
  A_Positive
  A_Negative
  B_Positive
  AB_Positive
  AB_Negative
  O_Positive
  O_Negative
}

enum LogAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  CREATE_CASE
  UPDATE_CASE
  DELETE_CASE
  IMPORT_CASES
  EXPORT_CASES
  CREATE_EMPLOYEE
  UPDATE_EMPLOYEE
  DELETE_EMPLOYEE
  IMPORT_EMPLOYEES
  EXPORT_EMPLOYEES
  CREATE_USER
  UPDATE_ROLE
  DEACTIVATE_USER
  REACTIVATE_USER
  CHANGE_PASSWORD
  SET_INITIAL_PASSWORD
  SEND_MAGIC_LINK
  RESET_PASSWORD
  UPDATE_PROFILE
  DELETE_USER
}

model Case {
  id                Int                @id @default(autoincrement())
  caseType          CaseType           @default(UNKNOWN)
  branch            String?
  assistantBranch   String?
  caseNumber        String
  number            Int?
  area              String?
  year              Int?
  isManual          Boolean            @default(false)
  dateFiled         DateTime?
  
  criminalCase      CriminalCase?
  petition          Petition?
  civilCase         CivilCase?
  specialProceeding SpecialProceeding?
  sheriffCase       SheriffCase?

  @@unique([caseType, year, area, number])
}

model CaseCounter {
  caseType  CaseType @default(CRIMINAL)
  area      String   @default("")
  year      Int
  last      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([caseType, area, year])
  @@index([area, year])
}

model CriminalCase {
  id             Int       @id @default(autoincrement())
  baseCaseID     Int       @unique
  name           String
  charge         String?
  infoSheet      String?
  court          String?
  detained       String?
  consolidation  String?
  eqcNumber      String?
  bond           String?
  raffleDate     DateTime?
  committee1     String?
  committee2     String?
  judge          String?
  ao             String?
  complainant    String?
  houseNo        String?
  street         String?
  barangay       String?
  municipality   String?
  province       String?
  counts         String?
  jdf            String?
  sajj           String?
  sajj2          String?
  mf             String?
  stf            String?
  lrf            String?
  vcf            String?
  total          String?
  amountInvolved String?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  case Case @relation(fields: [baseCaseID], references: [id], onDelete: Cascade)
}

model CivilCase {
  id                  Int       @id @default(autoincrement())
  baseCaseID          Int       @unique
  petitioners         String?
  defendants          String?
  notes               String?
  nature              String?
  originCaseNumber    String?
  reRaffleDate        DateTime?
  reRaffleBranch      String?
  consolitationDate   DateTime?
  consolidationBranch String?
  dateRemanded        DateTime?
  remandedNote        String?
  undocketed          Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  case Case @relation(fields: [baseCaseID], references: [id], onDelete: Cascade)
}

model Petition {
  id         Int       @id @default(autoincrement())
  baseCaseID Int       @unique
  petitioner String?
  raffledTo  String?
  date       DateTime?
  nature     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  case Case @relation(fields: [baseCaseID], references: [id], onDelete: Cascade)
}

model SpecialProceeding {
  id         Int       @id @default(autoincrement())
  baseCaseID Int       @unique
  petitioner String?
  raffledTo  String?
  date       DateTime?
  nature     String?
  respondent String?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  case Case @relation(fields: [baseCaseID], references: [id], onDelete: Cascade)
}

model Sherriff {
  id            Int       @id @default(autoincrement())
  ejfCaseNumber String?
  mortgagee     String?
  mortgagor     String?
  remarks       String?
  date          DateTime?
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @updatedAt @default(now())
}

model SheriffCase {
  id            Int       @id @default(autoincrement())
  baseCaseID    Int       @unique
  mortgagee     String?
  mortgagor     String?
  remarks       String?
  sheriffName   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  case Case @relation(fields: [baseCaseID], references: [id], onDelete: Cascade)
}

model Employee {
  id             Int            @id @default(autoincrement())
  employeeName   String
  employeeNumber String?        @unique
  position       String
  branch         String
  birthDate      DateTime
  dateHired      DateTime
  employmentType EmploymentType
  contactNumber  String?        @unique
  email          String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime?      @updatedAt
}

model Log {
  id     Int       @id @default(autoincrement())
  action LogAction

  // stores additional details about the log entry
  // id when creating or deleting
  // from and to when updating
  details Json?

  timestamp DateTime  @default(now())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Roles     @default(user)
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  branch        String?
  darkMode      Boolean?  @default(false)

  sessions Session[]
  accounts Account[]

  status       Status        @default(PENDING)
  chatMessages ChatMessage[]
  chatMembers  ChatMember[]

  Logs Log[]

  twoFactorEnabled Boolean?    @default(false)
  twofactors       TwoFactor[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  status                Status    @default(PENDING)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model RecievingLog {
  id           Int       @id @default(autoincrement())
  bookAndPage  String?
  dateRecieved DateTime?
  caseType     CaseType  @default(UNKNOWN)
  caseNumber   String?
  content      String?
  branchNumber String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime? @updatedAt
}

model Notarial {
  id       Int       @id @default(autoincrement())
  title    String?
  name     String?
  attorney String?
  date     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  file   FileData? @relation(fields: [fileId], references: [id])
  fileId Int?
}

model FileData {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  fileHash  String
  fileName  String
  path      String
  size      Int
  mimeType  String
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  notarials    Notarial[]
  chatMessages ChatMessage[]
}

model RegionalTrialCourt {
  id                      Int     @id @default(autoincrement())
  reportYear              Int?
  branch                  String
  pendingLastYear         String?
  RaffledOrAdded          String?
  Disposed                String?
  pendingThisYear         String?
  percentageOfDisposition String?

  @@index([reportYear])
}

model MunicipalTrialCourt {
  id                      Int     @id @default(autoincrement())
  reportYear              Int?
  branch                  String
  pendingLastYear         String?
  RaffledOrAdded          String?
  Disposed                String?
  pendingThisYear         String?
  percentageOfDisposition String?

  @@index([reportYear])
}

model InventoryDocument {
  id                       Int      @id @default(autoincrement())
  region                   String
  province                 String
  court                    String
  cityMunicipality         String
  branch                   String
  civilSmallClaimsFiled    String?
  criminalCasesFiled       String?
  civilSmallClaimsDisposed String?
  criminalCasesDisposed    String?
  dateRecorded             DateTime @default(now())
}

model monthlyStatistics {
  id       Int    @id @default(autoincrement())
  month    String // YYYY-MM
  category String
  branch   String
  criminal Int    @default(0)
  civil    Int    @default(0)
  total    Int    @default(0)

  @@unique([month, category, branch])
}

model JudgementMunicipal {
  id              Int     @id @default(autoincrement())
  branchNo        String?
  civilV          Int
  civilInc        Int
  criminalV       Int
  criminalInc     Int
  totalHeard      Int     @default(0)
  disposedCivil   Int     @default(0)
  disposedCrim    Int     @default(0)
  totalDisposed   Int     @default(0)
  pdlM            Int     @default(0)
  pdlF            Int     @default(0)
  pdlTotal        Int     @default(0)
  pdlV            Int     @default(0)
  pdlI            Int     @default(0)
  pdlBail         Int     @default(0)
  pdlRecognizance Int     @default(0)
  pdlMinRor       Int     @default(0)
  pdlMaxSentence  Int     @default(0)
  pdlDismissal    Int     @default(0)
  pdlAcquittal    Int     @default(0)
  pdlMinSentence  Int     @default(0)
  pdlOthers       Int     @default(0)
  total           Int     @default(0)
}

model JudgementRegional {
  id              Int     @id @default(autoincrement())
  branchNo        String?
  civilV          Int
  civilInc        Int
  criminalV       Int
  criminalInc     Int
  totalHeard      Int     @default(0)
  disposedCivil   Int     @default(0)
  disposedCrim    Int     @default(0)
  summaryProc     Int     @default(0)
  casesDisposed   Int     @default(0)
  pdlM            Int     @default(0)
  pdlF            Int     @default(0)
  pdlCICL         Int     @default(0)
  pdlTotal        Int     @default(0)
  pdlV            Int     @default(0)
  pdlInc          Int     @default(0)
  pdlBail         Int     @default(0)
  pdlRecognizance Int     @default(0)
  pdlMinRor       Int     @default(0)
  pdlMaxSentence  Int     @default(0)
  pdlDismissal    Int     @default(0)
  pdlAcquittal    Int     @default(0)
  pdlMinSentence  Int     @default(0)
  pdlProbation    Int     @default(0)
  ciclM           Int     @default(0)
  ciclF           Int     @default(0)
  ciclV           Int     @default(0)
  ciclInc         Int     @default(0)
  fine            Int     @default(0)
  total           Int     @default(0)
}

model Chat {
  id            Int      @id @default(autoincrement())
  type          ChatType @default(DIRECT)
  name          String?
  description   String?
  lastMessageAt DateTime @default(now())
  // call          Call?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  members  ChatMember[]
  messages ChatMessage[]
}

model ChatMember {
  id       Int      @id @default(autoincrement())
  chatId   Int
  userId   String
  joinedAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model ChatMessage {
  id      Int    @id @default(autoincrement())
  chatId  Int
  userId  String
  content String

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  fileId Int?
  file   FileData? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BackupFrequency {
  MANUAL
  DAILY
  WEEKLY
  MONTHLY
}

enum LogRetention {
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
  ONE_YEAR
  INDEFINITELY
}

enum PasswordExpiration {
  NEVER
  ONE_MONTH
  TWO_MONTHS
  THREE_MONTHS
  SIX_MONTHS
}

enum LockoutThreshold {
  NONE
  THREE_ATTEMPTS
  FIVE_ATTEMPTS
  TEN_ATTEMPTS
}

enum SessionTimeout {
  FIFTEEN_MINUTES
  THIRTY_MINUTES
  ONE_HOUR
  TWO_HOURS
  FOUR_HOURS
  EIGHT_HOURS
  NEVER
}

model SystemSettings {
  id Int @id @default(1)

  maintainanceMode   Boolean @default(false)
  systemAnnouncement String?

  smtpHost       String? @default("smtp.gmail.com")
  smtpPort       Int?    @default(587)
  senderName     String? @default("RTC Notifications")
  senderEmail    String? @default("noreply@rtc.com")
  senderPassword String?

  backupFrequency BackupFrequency @default(MANUAL)
  logRetention    LogRetention    @default(THREE_MONTHS)

  passwordExpiration PasswordExpiration @default(NEVER)
  lockoutThreshold   LockoutThreshold   @default(NONE)
  sessionTimeout     SessionTimeout     @default(NEVER)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt @default(now())
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}
