// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Roles {
  admin
  user
  atty
}

enum EmploymentType {
  PERMANENT
  CONTRACTUAL
  CASUAL
}

enum CaseType {
  CRIMINAL
  CIVIL
  LAND_REGISTRATION_CASE
  PETITION
  ELECTION
  SCA
  UNKNOWN
}

enum Status {
  INACTIVE
  ACTIVE
  DEACTIVATED
  PENDING
  SUSPENDED
  TERMINATED
}

enum BloodType {
  A_Positive
  A_Negative
  B_Positive
  B_Negative
  AB_Positive
  AB_Negative
  O_Positive
  O_Negative
}

enum LogAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  CREATE_CASE
  UPDATE_CASE
  DELETE_CASE
  IMPORT_CASES
  EXPORT_CASES
  CREATE_EMPLOYEE
  UPDATE_EMPLOYEE
  DELETE_EMPLOYEE
  IMPORT_EMPLOYEES
  EXPORT_EMPLOYEES
  CREATE_USER
  UPDATE_ROLE
  DEACTIVATE_USER
  REACTIVATE_USER
  CHANGE_PASSWORD
  SET_INITIAL_PASSWORD
  SEND_MAGIC_LINK
  RESET_PASSWORD
  UPDATE_PROFILE
  DELETE_USER
}

model Case {
  id              Int       @id @default(autoincrement())
  caseType        CaseType  @default(UNKNOWN)
  branch          String?
  assistantBranch String?
  caseNumber      String    @unique
  dateFiled       DateTime?
  
  criminalCase     CriminalCase?
  petition         Petition?
  specialProceeding SpecialProceeding?
}

model CriminalCase{
  id              Int       @id @default(autoincrement())
  caseNumber         String       @unique
  name            String
  charge          String?
  infoSheet       String?
  court           String?
  detained        String?
  consolidation   String?
  eqcNumber       Int?
  bond            String?
  raffleDate      DateTime?
  committee1      String?
  committee2      String?
  judge           String?
  ao              String?
  complainant     String?
  houseNo         String?
  street          String?
  barangay        String?
  municipality    String?
  province        String?
  counts          String?
  jdf             String?
  sajj            String?
  sajj2           String?
  mf              String?
  stf             String?
  lrf             String?
  vcf             String?
  total           String?
  amountInvolved  String?
  createdAt       DateTime  @default(now())

  case            Case      @relation(fields: [caseNumber], references: [caseNumber], onDelete: Cascade)
}

model Petition {
  id         Int       @id @default(autoincrement())
  caseNumber String    @unique
  petitioner String?
  raffledTo  String?
  date       DateTime?
  nature     String?

  case     Case      @relation(fields: [caseNumber], references: [caseNumber], onDelete: Cascade)
}

model SpecialProceeding {
  id         Int       @id @default(autoincrement())
  caseNumber String    @unique
  petitioner String?
  raffledTo  String?
  date       DateTime?
  nature     String?
  respondent String?

  case      Case      @relation(fields: [caseNumber], references: [caseNumber], onDelete: Cascade)
}

model Employee {
  id               Int        @id @default(autoincrement())
  employeeName     String
  employeeNumber   String?    @unique
  position         String
  branch           String
  birthDate        DateTime
  dateHired         DateTime
  employmentType EmploymentType
  contactNumber    String?    @unique
  email            String?    @unique
  createdAt        DateTime   @default(now())
}

model Log {
  id     Int       @id @default(autoincrement())
  action LogAction

  // stores additional details about the log entry
  // id when creating or deleting
  // from and to when updating
  details Json?

  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Roles     @default(user)
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]

  status Status @default(PENDING)

  Logs Log[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  status                Status    @default(PENDING)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model RecievingLog {
  id           Int       @id @default(autoincrement())
  bookAndPage  String?
  dateRecieved DateTime?
  caseType     CaseType  @default(UNKNOWN)
  caseNumber   String?
  content      String?
  branchNumber String?
  notes        String?
  createdAt    DateTime  @default(now())
}

model Notarial {
  id        Int      @id @default(autoincrement())
  title     String
  name      String
  attorney  String
  createdAt DateTime @default(now())
  date      DateTime

  file   NotarialFile? @relation(fields: [fileId], references: [id])
  fileId Int?
}

model NotarialFile {
  id        Int      @id @default(autoincrement())
  filename  String
  path      String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())

  notarials Notarial[]
}

model RegionalTrialCourt {
  id                      Int     @id @default(autoincrement())
  branch                  String
  pendingLastYear         String?
  RaffledOrAdded          String?
  Disposed                String?
  pendingThisYear         String?
  percentageOfDisposition String?
}

model MunicipalTrialCourt {
  id                      Int     @id @default(autoincrement())
  branch                  String
  pendingLastYear         String?
  RaffledOrAdded          String?
  Disposed                String?
  pendingThisYear         String?
  percentageOfDisposition String?
}

model InventoryDocument {
  id                       Int      @id @default(autoincrement())
  region                   String
  province                 String
  court                    String
  cityMunicipality         String
  branch                   String
  civilSmallClaimsFiled    String?
  criminalCasesFiled       String?
  civilSmallClaimsDisposed String?
  criminalCasesDisposed    String?
  dateRecorded             DateTime @default(now())
}

model monthlyStatistics {
  id       Int    @id @default(autoincrement())
  month    String // YYYY-MM
  category String
  branch   String
  criminal Int    @default(0)
  civil    Int    @default(0)
  total    Int    @default(0)

  @@unique([month, category, branch])
}

model JudgementMunicipal {
  id              Int     @id @default(autoincrement())
  branchNo        String?
  civilV          Int
  civilInc        Int
  criminalV       Int
  criminalInc     Int
  totalHeard      Int     @default(0)
  disposedCivil   Int     @default(0)
  disposedCrim    Int     @default(0)
  totalDisposed   Int     @default(0)
  pdlM            Int     @default(0)
  pdlF            Int     @default(0)
  pdlTotal        Int     @default(0)
  pdlV            Int     @default(0)
  pdlI            Int     @default(0)
  pdlBail         Int     @default(0)
  pdlRecognizance Int     @default(0)
  pdlMinRor       Int     @default(0)
  pdlMaxSentence  Int     @default(0)
  pdlDismissal    Int     @default(0)
  pdlAcquittal    Int     @default(0)
  pdlMinSentence  Int     @default(0)
  pdlOthers       Int     @default(0)
  total           Int     @default(0)
}

model JudgementRegional {
  id              Int     @id @default(autoincrement())
  branchNo        String?
  civilV          Int
  civilInc        Int
  criminalV       Int
  criminalInc     Int
  totalHeard      Int     @default(0)
  disposedCivil   Int     @default(0)
  disposedCrim    Int     @default(0)
  summaryProc     Int     @default(0)
  casesDisposed   Int     @default(0)
  pdlM            Int     @default(0)
  pdlF            Int     @default(0)
  pdlCICL         Int     @default(0)
  pdlTotal        Int     @default(0)
  pdlV            Int     @default(0)
  pdlInc          Int     @default(0)
  pdlBail         Int     @default(0)
  pdlRecognizance Int     @default(0)
  pdlMinRor       Int     @default(0)
  pdlMaxSentence  Int     @default(0)
  pdlDismissal    Int     @default(0)
  pdlAcquittal    Int     @default(0)
  pdlMinSentence  Int     @default(0)
  pdlProbation    Int     @default(0)
  ciclM           Int     @default(0)
  ciclF           Int     @default(0)
  ciclV           Int     @default(0)
  ciclInc         Int     @default(0)
  fine            Int     @default(0)
  total           Int     @default(0)
}
