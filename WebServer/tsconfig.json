{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../packages/shared/src/Case/Criminal/CriminalCasePage.tsx",
    "../packages/shared/src/Case/Criminal/CriminalCaseRow.tsx",
    "../packages/shared/src/Case/Criminal/CriminalCaseUpdatePage.tsx",
    "../packages/shared/src/utils.ts",
    "../packages/shared/src/Case/Civil/CivilCaseUpdatePage.tsx",
    "../packages/shared/src/Case/Petition/PetitionCasePage.tsx",
    "../packages/shared/src/Case/Petition/PetitionCaseRow.tsx",
    "../packages/shared/src/Case/Petition/PetitionCaseDetailsPage.tsx",
    "../packages/shared/src/Case/Petition/PetitionCaseUpdatePage.tsx",
    "../packages/shared/src/Case/RecievingLogs/ReceivingUpdatePage.tsx",
    "../packages/shared/src/Case/RecievingLogs/ReceivingLogs.tsx",
    "../packages/shared/src/Case/RecievingLogs/ReceivingRow.tsx",
    "../packages/shared/src/Case/RecievingLogs/RecievingLogsSchema.ts",
    "../packages/shared/src/Case/RecievingLogs/ReceivingDetailsPage.tsx",
    "../packages/shared/src/Case/Sherriff/SherriffSchema.ts",
    "../packages/shared/src/Case/Sherriff/SherriffCaseRow.tsx",
    "../packages/shared/src/Case/Sherriff/SherriffCaseUpdatePage.tsx",
    "../packages/shared/src/Case/Sherriff/SherriffUpdatePage.tsx",
    "../packages/shared/src/Case/Sherriff/Sherriff.tsx",
    "../packages/shared/src/Case/Sherriff/SheriffDetailsPage.tsx",
    "../packages/shared/src/Case/SpecialProceeding/SpecialProceedingsSchema.ts",
    "../packages/shared/src/Case/SpecialProceeding/SpecialProceedingRow.tsx",
    "../packages/shared/src/Case/SpecialProceeding/SpecialProceedingDetailsPage.tsx",
    "../packages/shared/src/Case/SpecialProceeding/SpecialProceedingUpdatePage.tsx",
    "../packages/shared/src/Case/SpecialProceeding/Proceedings.tsx"
  ],
  "exclude": ["node_modules"]
}
