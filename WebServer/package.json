{
  "name": "rtc-database-webserver",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n next,sidecar,prisma \"next dev\" \"pnpm dev:sidecar\" \"prisma studio --browser none\"",
    "dev:sidecar": "nodemon",
    "dev:noudp": "concurrently \"next dev\" \"prisma studio --browser none\"",
    "build": "next build && pnpm build:sidecar",
    "build:sidecar": "tsc -p tsconfig.server.json",
    "start:sidecar": "node dist/server.js",
    "start": "cross-env NODE_ENV=production concurrently -k -n next,sidecar \"next start\" \"pnpm start:sidecar\"",
    "lint": "eslint",
    "postinstall": "pnpm rebuild better-sqlite3 rclone.js",
    "prepare": "next-ws patch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@rtc-database/shared": "workspace:*",
    "better-auth": "^1.4.18",
    "better-sqlite3": "12.9.0",
    "cross-env": "^7.0.3",
    "daisyui": "^5.5.17",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.31.0",
    "lucide-react": "^0.563.0",
    "next": "16.2.3",
    "next-runtime-env": "^3.3.0",
    "next-ws": "^2.2.4",
    "nodemailer": "^8.0.5",
    "qrcode.react": "^4.2.0",
    "rclone.js": "^0.6.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "recharts": "^3.7.0",
    "server-only": "^0.0.1",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/rclone.js": "^0.6.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "nodemon": "^2.0.20",
    "prisma": "^7.3.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
