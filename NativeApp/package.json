{
  "name": "rtc-database-nativeapp",
  "productName": "RTC Database",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win nsis portable",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "postinstall": "node ./scripts/cleanupBrokenNodeModulesLinks.cjs && electron-rebuild -f -w better-sqlite3 && electron-builder install-app-deps && pnpm rebuild electron rclone.js"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/client-runtime-utils": "^7.7.0",
    "@prisma/client": "^7.3.0",
    "@prisma/debug": "^7.7.0",
    "@prisma/driver-adapter-utils": "^7.7.0",
    "@prisma/engines": "^7.7.0",
    "@prisma/fetch-engine": "^7.7.0",
    "@prisma/get-platform": "^7.7.0",
    "@rtc-database/shared": "workspace:*",
    "@rtc-database/shared-relay": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "bindings": "^1.5.0",
    "better-sqlite3": "12.8.0",
    "file-uri-to-path": "^1.0.0",
    "prebuild-install": "^7.1.3",
    "rclone.js": "^0.6.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.prynce0711.rtc-app",
    "icon": "public/SupremeCourtLogo.ico",
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "node_modules/.pnpm/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/rclone.js/bin/**/*"
    ],
    "win": {
      "icon": "public/SupremeCourtLogo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "directories": {
      "buildResources": "dist",
      "output": "release-builds"
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/rclone.js": "^0.6.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.0.0",
    "daisyui": "^5.5.19",
    "electron": "^41.2.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.27.7",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prisma": "^7.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "main": "dist-electron/main.js"
}
